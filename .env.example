# Local Postgres connection. Replit injects this automatically in deploys.
DATABASE_URL=postgresql://localhost/hifdh_tracker

# API server port (Express)
PORT=3000

# Vite frontend dev server port
VITE_PORT=5173

# Frontend base path (leave as "/" unless deploying under a sub-path)
BASE_PATH=/

# ── Quran Foundation Content API ────────────────────────────────
# These are SERVER-ONLY. Never expose to the browser bundle.
# Request access at https://api-docs.quran.foundation
QURAN_CLIENT_ID=your-client-id
QURAN_CLIENT_SECRET=your-client-secret
# "prelive" for sandbox during development, "production" for live
QURAN_ENV=prelive

# ── Optional: AI parser (Claude) for natural-language weekly entry ──
ANTHROPIC_API_KEY=
