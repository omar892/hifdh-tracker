# Local Postgres connection. Replit injects this automatically in deploys.
DATABASE_URL=postgresql://localhost/hifdh_tracker

# API server port (Express)
PORT=3000

# Vite frontend dev server port
VITE_PORT=5173

# Frontend base path (leave as "/" unless deploying under a sub-path)
BASE_PATH=/

# ── Quran Foundation Content API ────────────────────────────────
# These are SERVER-ONLY. Never expose to the browser bundle.
# Request access at https://api-docs.quran.foundation
QURAN_CLIENT_ID=your-client-id
QURAN_CLIENT_SECRET=your-client-secret
# "prelive" for sandbox during development, "production" for live
QURAN_ENV=prelive

# ── Quran Foundation User API (Streak Tracking integration) ─────
# The Production QF client typically ships with "NO authentication/user
# features by default" — so for testing/demo, point this at the
# Pre-Production (Test) client which has all features enabled. Set
# QF_USER_ENV=prelive to hit the prelive OAuth + API endpoints
# independently of QURAN_ENV.
QF_USER_ENV=prelive
QF_USER_CLIENT_ID=
QF_USER_CLIENT_SECRET=
# Must exactly match the redirect URI registered in the QF developer console.
# Local dev example:   http://localhost:3000/api/qf-link/callback
# Railway production:  https://<your-railway-domain>/api/qf-link/callback
QF_USER_REDIRECT_URI=http://localhost:3000/api/qf-link/callback
# Optional: where to bounce the admin after a successful link. Defaults to
# the Referer header, then "/". Set this on Railway to your settings page URL.
QF_USER_POST_LINK_REDIRECT=/settings
# AES-256 key (base64) used to encrypt refresh tokens at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
QF_TOKEN_ENCRYPTION_KEY=

# ── Optional: AI parser (Claude) for natural-language weekly entry ──
ANTHROPIC_API_KEY=
